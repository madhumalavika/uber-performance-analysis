                    "value": ""
                  }
                ]
              },
              {
                "textRuns": [
                  {
                    "value": "Trip ID",
                    "textStyle": {
                      "fontWeight": "bold",
                      "fontSize": "14pt"
                    }
                  },
                  {
                    "value": " – A unique identifier assigned to each Uber trip. This helps in tracking individual rides.",
                    "textStyle": {
                      "fontSize": "14pt"
                    }
