table 'Trip Details'
	lineageTag: b304831f-4ae8-4463-b26f-9405ea41305b

	measure 'Total Bookings' = count('Trip Details'[Trip ID])
		formatString: 0
		lineageTag: 83b57cf5-98cf-450e-a01b-b0c07fbabef6

		changedProperty = IsHidden

	measure 'Total Booking Value' = SUM('Trip Details'[fare_amount])+SUM('Trip Details'[Surge Fee])
		formatString: \$#,0.0;(\$#,0.0);\$#,0.0
		lineageTag: 877f5915-55e2-4def-992c-8212fa1b9f86

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Average Booking Value' = DIVIDE([Total Booking Value],[Total Bookings],BLANK())
		formatString: \$#,0.0;(\$#,0.0);\$#,0.0
		lineageTag: acef392d-9896-4211-8a5a-d2ca42569d93

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"currencyCulture":"en-US"}

	measure 'Total Trip Distance(text)' =
			
			var Totalmiles = SUM('Trip Details'[trip_distance])/1000
			RETURN
			CONCATENATE(FORMAT(Totalmiles,"0"),"K Miles")
		lineageTag: 6eafa433-bf24-4362-bc87-d30c2a57c916

		changedProperty = IsHidden

	measure 'Average Trip Distance' =
			
			VAR Avgmiles=ROUND(AVERAGE('Trip Details'[trip_distance]),0)
			RETURN
			CONCATENATE(Avgmiles," Miles")
		lineageTag: ce51d47c-89ee-450c-846e-a0ab3fae0982

		changedProperty = IsHidden

	measure 'Average Trip Time' =
			
			VAR avgtriptime = AVERAGEX(
			                        'Trip Details',DATEDIFF('Trip Details'[Pickup Time],'Trip Details'[Drop Off Time],MINUTE))
			                        RETURN
			                        CONCATENATE(FORMAT(avgtriptime,"0")," Min")
		lineageTag: 59f860b9-a0f8-4059-a72f-adfb2d008eeb

		changedProperty = IsHidden

	measure 'Total Trip Distance (Numerical value)' = SUM('Trip Details'[trip_distance])
		lineageTag: e23430b3-f5ce-4d9f-bcd9-36b0bec0c794

		changedProperty = IsHidden

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Title for Grid' = "Vehicle Type Analysis"
		lineageTag: e642f2ce-d4c3-4365-8f81-c4f489daaa36

		changedProperty = IsHidden

	measure 'Most Frequent PU_Point' = ```
			
			VAR Pickpoint = TOPN(1,
			                        SUMMARIZE( 
			                                   'Trip Details','Location Table'[Location],"Pickup Point",count('Trip Details'[Trip ID])
			                        ),
			                        [Pickup Point],DESC
			)
			RETURN
			CONCATENATEX(Pickpoint,'Location Table'[Location],",")
			```
		lineageTag: 6d8ce6de-fd1b-4c9c-bb97-8199a8bf8917

		changedProperty = IsHidden

	measure 'Most Frequent Drop Off_Point' = ```
			
			VAR Dropoffcounts=
			    ADDCOLUMNS(
			        summarize(
			            'Trip Details',
			            'Location Table'[Location]
			        ),
			        "DropoffCount",
			        CALCULATE(
			            COUNT('Trip Details'[Trip ID]),
			            USERELATIONSHIP('Trip Details'[DOLocationID],'Location Table'[LocationID])
			        )
			    )
			
			VAR RankedDropoffs=
			    ADDCOLUMNS(
			        Dropoffcounts,
			        "Rank",
			        RANKX(Dropoffcounts,[DropoffCount],,DESC,DENSE)
			    )
			
			VAR TopDropoff=
			    FILTER(RankedDropoffs,[Rank]=1)
			RETURN
			CONCATENATEX(TopDropoff,'Location Table'[Location],",")
			
			```
		lineageTag: 65594a58-11f4-4683-8e89-ee0c31324172

		changedProperty = IsHidden

	measure 'Fartherst Trip' =
			
			VAR Maxdistance = MAX('Trip Details'[trip_distance])
			
			VAR PickupLocation=
			    LOOKUPVALUE('Location Table'[Location],'Location Table'[LocationID],CALCULATE(SELECTEDVALUE('Trip Details'[PULocationID]),'Trip Details'[trip_distance]=Maxdistance))
			
			VAR DropoffLocation =
			    LOOKUPVALUE('Location Table'[Location],'Location Table'[LocationID],CALCULATE(SELECTEDVALUE('Trip Details'[DOLocationID]),'Trip Details'[trip_distance]=Maxdistance))
			Return
			"Pickup: " & PickupLocation & " → Drop-Off: " & DropoffLocation & " (" & FORMAT(Maxdistance,"0.0") & " Miles)"
		lineageTag: 99ebf2e4-c0e4-4ea8-81c2-7f1856fbaad7

		changedProperty = IsHidden

	measure 'Title for Location' = "Location Analysis"
		lineageTag: 7707f95e-2f84-45a0-9d19-bad64673f792

		changedProperty = IsHidden

	measure 'Title for Pickup_time (Dynamic)' = SELECTEDVALUE('Dynamic Measure'[Dynamic Title]) & " by Pickup Time"
		lineageTag: 8207ec9a-4959-4f8b-bfc6-fc541d71ee8a

	measure 'Title for Pickup_day (Dynamic)' = SELECTEDVALUE('Dynamic Measure'[Dynamic Title]) & " by Day Name"
		lineageTag: 10ecba19-83c5-41a2-b4b6-f6aff95d0e70

	measure 'Title for Pickup Hour of time (Dynamic)' = SELECTEDVALUE('Dynamic Measure'[Dynamic Title]) & " by Pickup Time"
		lineageTag: 5bc454f2-3587-44a2-ae15-12b219da1ce9

