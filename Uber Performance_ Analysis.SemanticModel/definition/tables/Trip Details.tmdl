	column 'Trip Type (Day/Night)' =
			
			VAR HourofDay=HOUR('Trip Details'[Pickup Time])
			RETURN
			IF(HourofDay >= 18 || HourofDay < 6,"Night Trip","Day Trip")
		lineageTag: 34033a93-f372-4f8b-aa64-c34f5ae0c16e
